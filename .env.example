VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional external Spring Boot assistant backend.
# Leave empty to use the existing Vercel /api/chat route.
VITE_ASSISTANT_API_BASE_URL=

# Backend-only Vercel variables for manual email updates.
ADMIN_SEND_SECRET=
NEWSLETTER_SECRET=
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_REPLY_TO=
SITE_URL=https://saikumarmediboina.com

# Preferred: base64-encoded Firebase service account JSON.
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Alternative if not using FIREBASE_SERVICE_ACCOUNT_BASE64.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_PRIVATE_KEY_BASE64=

# Backend-only Vercel variables for the Gemini chat assistant.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional Spring assistant backend provider variables.
LLM_PROVIDER=local
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1
EMBEDDING_PROVIDER=local
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSION=1536
