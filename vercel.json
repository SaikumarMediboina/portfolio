{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/blog/:slug",
      "destination": "/index.html"
    },
    {
      "source": "/signin",
      "destination": "/index.html"
    },
    {
      "source": "/start",
      "destination": "/index.html"
    },
    {
      "source": "/learn-with-me",
      "destination": "/index.html"
    },
    {
      "source": "/active-builds",
      "destination": "/index.html"
    },
    {
      "source": "/active-builds/:slug",
      "destination": "/index.html"
    },
    {
      "source": "/whats-new",
      "destination": "/index.html"
    },
    {
      "source": "/saved-posts",
      "destination": "/index.html"
    },
    {
      "source": "/shelf",
      "destination": "/index.html"
    },
    {
      "source": "/blogs",
      "destination": "/index.html"
    },
    {
      "source": "/ai-radar",
      "destination": "/index.html"
    },
    {
      "source": "/dashboard",
      "destination": "/index.html"
    },
    {
      "source": "/work-with-me",
      "destination": "/index.html"
    },
    {
      "source": "/about",
      "destination": "/index.html"
    },
    {
      "source": "/contact",
      "destination": "/index.html"
    },
    {
      "source": "/portfolio",
      "destination": "/index.html"
    },
    {
      "source": "/admin-update",
      "destination": "/index.html"
    }
  ]
}
